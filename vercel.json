{
  "functions": {
    "api/files/[...path].js": {
      "includeFiles": "files/**"
    }
  },
  "crons": [
    {
      "path": "/api/push-reminders?mode=plan&write=true",
      "schedule": "5 4,5 * * *"
    },
    {
      "path": "/api/push-reminders?mode=dispatch&dryRun=false&windowMinutes=15",
      "schedule": "*/15 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/external/:path*",
      "destination": "/api/external?path=:path*"
    },
    {
      "source": "/files/:path*",
      "destination": "/api/files/:path*"
    },
    {
      "source": "/",
      "destination": "/api"
    }
  ]
}
