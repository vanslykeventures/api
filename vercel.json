{
  "functions": {
    "api/files/[...path].js": {
      "includeFiles": "files/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/external/:path*",
      "destination": "/api/external?path=:path*"
    },
    {
      "source": "/files/:path*",
      "destination": "/api/files/:path*"
    },
    {
      "source": "/",
      "destination": "/api"
    }
  ]
}
